# Minimum required
COUNTA_FERNET_KEY=change-me-to-a-long-random-string

# Web
COUNTA_WEB_BASE_URL=https://counta.avalone.online
COUNTA_WEB_HOST=127.0.0.1
COUNTA_WEB_PORT=8810

# Registration mode: open | invite | closed
COUNTA_REGISTRATION_MODE=open
COUNTA_REGISTRATION_INVITE_CODE=
COUNTA_STRICT_PASSWORD_POLICY=false

# Optional: SMTP for email verification / password reset
COUNTA_SMTP_HOST=smtp.gmail.com
COUNTA_SMTP_PORT=465
COUNTA_SMTP_USER=
COUNTA_SMTP_PASSWORD=
COUNTA_SMTP_FROM=
