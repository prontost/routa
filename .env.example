# Minimum required
ROUTA_FERNET_KEY=change-me-to-a-long-random-string

# Web
ROUTA_WEB_BASE_URL=https://work.avalone.online
ROUTA_WEB_HOST=127.0.0.1
ROUTA_WEB_PORT=8810

# Registration mode: open | invite | closed
ROUTA_REGISTRATION_MODE=open
ROUTA_REGISTRATION_INVITE_CODE=
ROUTA_STRICT_PASSWORD_POLICY=false

# Optional: SMTP for email verification / password reset
ROUTA_SMTP_HOST=smtp.gmail.com
ROUTA_SMTP_PORT=465
ROUTA_SMTP_USER=
ROUTA_SMTP_PASSWORD=
ROUTA_SMTP_FROM=
